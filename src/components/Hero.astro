---
import { Image } from 'astro:assets';
import myPhoto from '../assets/my-photo.jpg';
---

<section class="hero">
  <div class="hero-content">
    <p class="hero-description">
      Pracuji v IT, dobrovolničím a studuji práva.
    </p>
    <p class="hero-subtext">
      Svůj web využívám jako prostor pro myšlenky a projekty, které chci sdílet s přáteli i veřejností.
    </p>
  </div>
  
  <div class="hero-image-wrapper">
    <Image 
      src={myPhoto} 
      alt="Adam Martinek" 
      width={400} 
      height={400} 
      loading="eager"
      class="hero-img"
    />
  </div>
</section>

<style>
  .hero {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 4rem;
    padding: 4rem 0;
  }

  .hero-content {
    flex: 1;
  }

  .hero-description {
    font-size: 2rem;
    font-weight: bold;
    color: var(--default-heading-color);
    line-height: 1.2;
    margin-bottom: 1.5rem;
  }

  .hero-subtext {
    font-size: 1.2rem;
    color: var(--default-text-color);
    opacity: 0.9;
  }

  .hero-image-wrapper {
    flex: 1;
    display: flex;
    justify-content: center;
  }

  .hero-img {
    border-radius: 50%;
    border: 4px solid var(--default-heading-color);
    object-fit: cover;
    box-shadow: 0 10px 30px color-mix(in srgb, var(--default-text-color), transparent 80%);
  }

  /* Responsive for mobile */
  @media (max-width: 768px) {
    .hero {
      flex-direction: column-reverse;
      text-align: center;
      gap: 2rem;
    }
    .hero-description {
      font-size: 1.5rem;
    }
  }
</style>